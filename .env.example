# Walk Score API — free tier at https://www.walkscore.com/professional/api.php
# Required for step 03. Without it, pipeline falls back to OSM-only scoring.
WALKSCORE_API_KEY=

# NOAA Climate Data Online token — free at https://www.ncdc.noaa.gov/cdo-web/token
# Optional — used in step 05 to verify seasonal climate suitability
NOAA_CDO_TOKEN=
